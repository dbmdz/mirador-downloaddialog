{
  "name": "mirador-downloaddialog",
  "version": "1.0.0",
  "description": "Mirador 4 plugin to add a dialog containing download links",
  "keywords": [
    "iiif",
    "mirador",
    "mirador4",
    "mirador-plugin",
    "react-component"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dbmdz/mirador-downloaddialog"
  },
  "license": "MIT",
  "author": "Matthias Lindinger <matthias.lindinger@bsb-muenchen.de>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "tsc && BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "tsc && vite build",
    "format": "eslint . --ext js,jsx,ts,tsx --fix --max-warnings 0 --report-unused-disable-directives",
    "lint": "eslint . --ext js,jsx,ts,tsx --max-warnings 0 --report-unused-disable-directives",
    "prepublishOnly": "npm run build",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "mirador": "^4.0.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "mirador": "4.x",
    "react": "19.x",
    "react-dom": "19.x",
    "reselect": "^5.1.1"
  },
  "engines": {
    "npm": ">=11.0.0"
  }
}
