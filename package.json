{
  "name": "mirador-downloaddialog",
  "version": "0.4.0",
  "description": "Mirador 4 plugin to add a dialog containing download links",
  "keywords": [
    "iiif",
    "mirador",
    "mirador4",
    "mirador-plugin",
    "react-component"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dbmdz/mirador-downloaddialog"
  },
  "license": "MIT",
  "author": "Matthias Lindinger <matthias.lindinger@bsb-muenchen.de>",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "vite build",
    "clean": "rimraf dist",
    "format": "eslint . --fix",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "mirador": "^4.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=5",
    "@mui/material": ">=5",
    "mirador": "4.x",
    "react": "19.x",
    "react-dom": "19.x"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "engines": {
    "npm": ">=11.0.0"
  }
}
